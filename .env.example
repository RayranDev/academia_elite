UPLOADS_DIR="./storage/uploads"
# Secreto del cron de la curva de desarrollo (Vercel Cron lo envía como
# Authorization: Bearer ...). Generar uno aleatorio en producción.
CRON_SECRET="cambiar-en-produccion"
